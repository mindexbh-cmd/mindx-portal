__pycache__/
*.pyc
# Ignore Claude Code local state but keep the committed subagent
# team and slash commands — agents/ and commands/ ship with the repo
# so every clone gets the team and the project-specific commands.
.claude/*
!.claude/agents/
!.claude/commands/
!.claude/mcp_servers.json
mindx.db
test_*.db

# Generated artifacts from the docs system (Phase 1).
# Each environment captures its own; nothing to track in git.
static/docs/screenshots/*.png
static/docs/screenshots/*.jpg

# Local-only artifacts from import / cleanup operations.
# Backups belong on the persistent disk in production, not in git.
attendance_clean.csv
backups/
data/curriculum/
*.sql

# Playwright e2e captures — overwritten on every run, no point in versioning.
scripts/screenshots/
