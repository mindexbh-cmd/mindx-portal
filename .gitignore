__pycache__/
*.pyc
# Ignore Claude Code local state but keep the committed subagent
# team and slash commands — agents/ and commands/ ship with the repo
# so every clone gets the team and the project-specific commands.
.claude/*
!.claude/agents/
!.claude/commands/
!.claude/hook_scripts/
!.claude/mcp_servers.json
mindx.db
test_*.db

# Generated artifacts from the docs system (Phase 1).
# Each environment captures its own; nothing to track in git.
static/docs/screenshots/*.png
static/docs/screenshots/*.jpg

# Local-only artifacts from import / cleanup operations.
# Backups belong on the persistent disk in production, not in git.
attendance_clean.csv
backups/
data/curriculum/
*.sql

# Playwright e2e captures — overwritten on every run, no point in versioning.
scripts/screenshots/

# Persona-harness scratch — debug throwaways and transient run output.
# The durable harnesses (parent_portal_walk.py, verify_parent_hub_tabs.py)
# are committed; everything else under scripts/personas/ is local-only.
scripts/personas/__pycache__/
scripts/personas/report.json
scripts/personas/debug*.py

# Ad-hoc diagnostic dumps from local debugging sessions — never committed.
# Root-level scratch files (.json/.html/.bin/.txt/.png) produced by quick
# probes (curl outputs, books diagnostic dumps, prod-page comparisons).
/*.json
/*.html
/*.bin
/*.txt
/*.png
/*.js

# Smoke-test + ad-hoc audit capture files written during local iteration.
# Always regenerable from scripts/run_e2e.py; no point versioning the
# transient stdout/stderr blobs.
scripts/smoke_*.out
scripts/smoke_*.err
scripts/*_audit.out
scripts/*_audit.err
scripts/grammar_*.out
scripts/grammar_*.err

# Ad-hoc probe / one-off test scripts. The formal test suite lives in
# scripts/run_e2e.py; anything matching scripts/test_*.py is a throwaway
# debugger kept locally for the duration of an investigation.
scripts/test_*.py
scripts/test_*.pdf
scripts/test_*.html
scripts/import_all_students.py
students_raw.tsv

# Root-level uploads dir (production uses /var/data; local scratch only).
uploads/

# Local runtime upload directory (production stores uploads on the
# persistent disk at /var/data; locally it's a scratch dir we don't
# commit).
data/uploads/

# Local-only diagnostic reports + investigation drafts. The durable
# docs live under docs/; reports/ is a scratchpad and *-investigation.md
# / *-report.md are intentionally-uncommitted drafts.
reports/
docs/*-investigation.md
docs/*-report.md
