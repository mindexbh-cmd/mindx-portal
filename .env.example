# Mindex portal — environment variables
#
# Copy this file to `.env` and fill in real values for local dev.
# Production values live in Render → mindx-portal → Environment.

# Flask session signing key. Render auto-generates one; locally
# any non-empty string works (default falls back to "mindx2026secret").
SECRET_KEY=

# SQLite path. Production (Render) uses /var/data/mindx.db so the
# DB lives on the persistent disk. Local default is mindx.db in
# the repo root.
DB_PATH=

# Postgres URL — set on Render only. Leaving this blank locally
# routes the app through the SQLite path (USE_PG=False).
DATABASE_URL=

# ── Cloudinary (curriculum file storage) ───────────────────────────
# Required for /admin/books uploads. Without all three, uploads
# return a clear error and view/download fall back to the legacy
# file_path column (so existing books keep working). Get values
# from https://dashboard.cloudinary.com → Settings → API Keys.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
